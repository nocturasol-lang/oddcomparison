# Production secrets and config. Copy to .env and set values.
# Do not commit .env.

# Redis (required for production)
REDIS_PASSWORD=your_redis_password_here

# Grafana admin
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password_here
GRAFANA_ROOT_URL=https://grafana.yourdomain.com

# Optional: Laystars scraper session cookies (from browser after login)
LAYSTARS_COOKIES=

# Optional: API rate limits (defaults in main.py)
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW_SEC=60

# Optional: orchestrator auto-recovery (circuit breaker + webhook alerts)
# RECOVERY_WEBHOOK_URL=https://your-server.com/webhooks/oddshawk
# CIRCUIT_FAILURE_THRESHOLD=3
# CIRCUIT_OPEN_SEC=60

# SSL: place cert.pem and key.pem in ./nginx/ssl/ for Nginx HTTPS.
# Or use Let's Encrypt and mount the certs there.
